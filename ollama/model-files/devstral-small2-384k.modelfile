# Ollama Modelfile — Devstral Small 2 (384k native context)
# num_ctx set to 393216 per HF config.json max_position_embeddings = 393216; YaRN rope scaling from 8K base
# Research: Official Mistral AI documentation + community coding agent tuning
# Sources: https://docs.mistral.ai/models/tools/
# NOTE: temperature=0.15 is appropriate for Mistral code models (deterministic output). repeat_penalty was missing — added per AkitaOnRails findings (~1.1 prevents verbatim repetitions).
FROM devstral-small-2:24b

# --- Sampling: Mistral coding settings ---
# temperature=0.15 — official Mistral coding temp; low for deterministic, precise code output (Markaicode: 0.1–0.3 for factual/technical content)
# top_p=1.0 — official Mistral setting; per community findings: fine at this level with low temperature
# top_k=40 — Ollama default; sufficient for Mistral's vocabulary
# repeat_penalty=1.10 — NEW: per AkitaOnRails: ~1.1 prevents unnecessary repetitions especially of code blocks; was missing (implicit 1.0 = disabled)
PARAMETER temperature 0.15
PARAMETER top_p 1.0
PARAMETER top_k 40
PARAMETER repeat_penalty 1.10

# --- Context & Generation ---
PARAMETER num_ctx 393216
PARAMETER num_predict 8192
