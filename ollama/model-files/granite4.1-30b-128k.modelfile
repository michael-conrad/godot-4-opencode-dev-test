# Ollama Modelfile — Granite 4.1 30B (131K native context)
# num_ctx set to 131072 per HF config.json max_position_embeddings = 131072; IBM blog claimed 512K but model card is authoritative
# Research: Official IBM documentation + community coding agent tuning
# Sources: https://www.ibm.com/docs/en/watsonx-ai/foundation-models/4.1
# NOTE: temperature=1.0 with "Muon optimizer handles diversity" rationale is a training-time concept, not applicable at inference — high temp causes hallucinations in code generation (Markaicode). Set to 0.3–0.5 for coding precision.
FROM granite4.1:30b

# --- Sampling: Coding agent settings ---
# temperature=0.4 — IBM's "Muon handles diversity" rationale is a training-time concept, not applicable at inference; per Markaicode: 1.0 causes hallucinations in code; 0.3–0.5 balances precision with reasoning flexibility for agentic work
# top_p=0.95 — IBM recommended default
# top_k=64 — IBM recommended default
# repeat_penalty=1.10 — per AkitaOnRails: ~1.1 prevents unnecessary repetitions; 1.0 is neutral/disabled and too conservative for agent work where repetition is a known failure mode
PARAMETER temperature 0.4
PARAMETER top_p 0.95
PARAMETER top_k 64
PARAMETER repeat_penalty 1.10

# --- Context & Generation ---
PARAMETER num_ctx 131072
PARAMETER num_predict 8192
